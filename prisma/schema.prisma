generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───

enum Role {
  ACCOUNTANT
  SENIOR_MERCHANDISER
  PRODUCTION_MANAGER
  MERCHANDISER
  STORE_MANAGER
  RUNNER
  CEO
}

enum OrderType {
  SAMPLE
  PRODUCTION
}

enum OrderStatus {
  ORDER_RECEIVED
  REQUEST_RAISED
  INVOICE_SUBMITTED
  APPROVED
  PAID
  COMPLETED
  CANCELLED
}

enum MaterialRequirementStatus {
  PENDING_STORE_ACCEPTANCE
  ACCEPTED_BY_STORE
  DECLINED_BY_STORE
  REQUEST_RAISED
  COMPLETED
}

enum PurchaseStatus {
  PENDING_PURCHASE
  SELF_PURCHASE
  INVOICE_SUBMITTED
  APPROVED
  PAID
  PARTIALLY_PAID
  COMPLETED
  REJECTED
  CANCELLED
}

enum PaymentMethod {
  CASH
  UPI
  BANK_TRANSFER
  CHEQUE
}

enum ConfirmStatus {
  NOT_CONFIRMED
  SHOWN_TO_VENDOR
  VENDOR_CONFIRMED
}

enum RunnerStatus {
  AVAILABLE
  ON_TASK
}

enum ExpenseStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
  PENDING_PAYMENT
  PAID
  COMPLETED
  CANCELLED
}

enum ExpenseCategory {
  JOB_WORK
  COURIER_SHIPPING
  LABOUR_OVERTIME
  MACHINE_REPAIR
  TESTING_LAB
  PACKAGING
  TRANSPORTATION
  WASHING_DYEING
  EMBROIDERY_PRINTING
  CUTTING_CHARGES
  FINISHING_CHARGES
  MISCELLANEOUS
}

enum BlockerCode {
  WAITING_PM_ACCEPTANCE
  WAITING_MERCH_ACCEPTANCE
  WAITING_TECHPACK_SUBMISSION
  WAITING_PM_REVIEW
  WAITING_BUYER_DECISION
  WAITING_STORE_ACCEPTANCE
  WAITING_PURCHASE_REQUEST
  WAITING_RUNNER_ACCEPTANCE
  WAITING_INVOICE_UPLOAD
  WAITING_ACCOUNTANT_APPROVAL
  WAITING_PAYMENT
  WAITING_VENDOR_CONFIRMATION
  WAITING_EXPENSE_COMPLETION
  WAITING_PRODUCTION_ACCEPTANCE
  WAITING_FINAL_SIGNOFF
}

enum ExceptionFlag {
  MISSING_DOCUMENT
  OVERDUE_REQUIRED_DATE
  VENDOR_MISMATCH
  BLOCKED_BY_APPROVAL
  REOPENED_ITEM
  HIGH_REVISION_COUNT
  DELAYED_SHIPPING_RISK
}

enum CommentEntityType {
  ORDER
  MATERIAL_REQUIREMENT
  MATERIAL_REQUEST
  PURCHASE
  EXPENSE_REQUEST
}

enum CostStatus {
  ON_BUDGET
  WARNING
  OVER_BUDGET
}

// ─── MODELS ───

model User {
  id                   String       @id @default(uuid())
  name                 String
  email                String       @unique
  password_hash        String
  role                 Role
  is_active            Boolean      @default(true)
  must_change_password Boolean      @default(false)
  last_login_at        DateTime?
  runner_status        RunnerStatus @default(AVAILABLE)
  current_task_id      String?
  created_by_id        String?
  created_at           DateTime     @default(now())
  updated_at           DateTime     @updatedAt

  created_by                    User?                @relation("UserCreatedBy", fields: [created_by_id], references: [id])
  created_users                 User[]               @relation("UserCreatedBy")
  created_vendors               Vendor[]             @relation("VendorCreatedBy")
  created_materials             Material[]           @relation("MaterialCreatedBy")
  created_styles                Style[]              @relation("StyleCreatedBy")
  created_buyers                Buyer[]              @relation("BuyerCreatedBy")
  created_orders                Order[]              @relation("OrderCreatedBy")
  assigned_sample_pm_orders     Order[]              @relation("OrderAssignedSamplePM")
  assigned_production_pm_orders Order[]              @relation("OrderAssignedProductionPM")
  pm_accepted_orders            Order[]              @relation("OrderPMAcceptedBy")
  material_completed_orders     Order[]              @relation("OrderMaterialCompletedBy")
  production_started_orders     Order[]              @relation("OrderProductionStartedBy")
  production_completed_orders   Order[]              @relation("OrderProductionCompletedBy")
  pm_material_requirements      MaterialRequirement[] @relation("MaterialRequirementPM")
  sm_material_requirements      MaterialRequirement[] @relation("MaterialRequirementSM")
  managed_requests              MaterialRequest[]    @relation("MaterialRequestManager")
  assigned_requests             MaterialRequest[]    @relation("MaterialRequestRunner")
  purchases                     Purchase[]           @relation("PurchaseRunner")
  payments                      Payment[]            @relation("PaymentAccountant")
  vendor_confirmations          VendorConfirmation[] @relation("ConfirmationRunner")
  raised_expenses               ExpenseRequest[]     @relation("ExpenseRaisedBy")
  notifications                 Notification[]       @relation("UserNotification")
  audit_logs                    AuditLog[]           @relation("AuditLogUser")
  reopened_orders               Order[]              @relation("OrderReopenedBy")
  next_action_orders            Order[]              @relation("OrderNextActionUser")
  reopened_purchases            Purchase[]           @relation("PurchaseReopenedBy")
  reopened_expenses             ExpenseRequest[]     @relation("ExpenseReopenedBy")
  comments                      Comment[]            @relation("CommentAuthor")
  mentioned_in_comments         CommentMention[]     @relation("MentionedUser")
  saved_filters                 SavedFilter[]        @relation("UserSavedFilter")
  recent_items                  RecentItem[]         @relation("UserRecentItem")
  sent_reminders                Reminder[]           @relation("ReminderSentBy")
  received_reminders            Reminder[]           @relation("ReminderTargetUser")

  @@index([role])
  @@index([is_active])
  @@index([runner_status])
  @@index([created_by_id])
}

model Vendor {
  id                 String   @id @default(uuid())
  name               String
  gstin              String?
  contact_person     String?
  phone              String?
  address            String?
  notes              String?
  is_active          Boolean  @default(true)
  created_inline     Boolean  @default(false)
  created_by_user_id String?
  created_at_stage   String?
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  created_by        User?             @relation("VendorCreatedBy", fields: [created_by_user_id], references: [id])
  material_requests MaterialRequest[] @relation("RequestPreferredVendor")
  purchases         Purchase[]        @relation("PurchaseVendor")
  expenses          ExpenseRequest[]  @relation("ExpenseVendor")

  @@index([created_by_user_id])
  @@index([is_active])
}

model Buyer {
  id              String   @id @default(uuid())
  name            String
  brand_code      String?  @unique
  address          String?
  shipping_address String?
  email            String?
  contact_person  String?
  phone           String?
  notes           String?
  created_inline  Boolean  @default(false)
  created_by_user_id String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  created_by            User?                @relation("BuyerCreatedBy", fields: [created_by_user_id], references: [id])
  orders                Order[]              @relation("OrderBuyer")
  material_requirements MaterialRequirement[] @relation("MaterialRequirementBuyer")
  material_requests     MaterialRequest[]    @relation("RequestBuyer")
  expenses              ExpenseRequest[]     @relation("ExpenseBuyer")

  @@index([created_by_user_id])
}

model Style {
  id                 String   @id @default(uuid())
  style_code         String   @unique
  style_name         String
  category           String?
  description        String?
  is_active          Boolean  @default(true)
  created_inline     Boolean  @default(false)
  created_by_user_id String?
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  created_by              User?                @relation("StyleCreatedBy", fields: [created_by_user_id], references: [id])
  order_lines             OrderLine[]
  material_requirements   MaterialRequirement[] @relation("MaterialRequirementStyle")
  material_requests       MaterialRequest[]    @relation("RequestStyle")
  material_request_lines  MaterialRequestLine[]
  purchase_lines          PurchaseLine[]       @relation("PurchaseLineStyle")
  expenses                ExpenseRequest[]     @relation("ExpenseStyle")

  @@index([created_by_user_id])
  @@index([is_active])
}

model Material {
  id                 String   @id @default(uuid())
  sku_code           String?  @unique
  description        String
  category           String
  unit_of_measure    String
  default_rate       Float?
  created_inline     Boolean  @default(false)
  created_by_user_id String?
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  created_by     User?               @relation("MaterialCreatedBy", fields: [created_by_user_id], references: [id])
  request_lines  MaterialRequestLine[]
  purchase_lines PurchaseLine[]

  @@index([created_by_user_id])
  @@index([category])
}

model Order {
  id                          String      @id @default(uuid())
  order_no                    String      @unique
  buyer_id                    String
  order_date                  DateTime
  shipping_date               DateTime
  order_type                  OrderType
  total_amount                Float
  remarks                     String?
  status                      OrderStatus @default(ORDER_RECEIVED)
  created_by                  String
  assigned_sample_pm_id       String?
  assigned_production_pm_id   String?
  pm_accepted_at              DateTime?
  pm_accepted_by_id           String?
  pm_acceptance_notes         String?
  material_completed_at       DateTime?
  material_completed_by_id    String?
  production_started_at       DateTime?
  production_started_by_id    String?
  production_completed_at     DateTime?
  production_completed_by_id  String?
  production_completion_notes String?
  // ─── Operational Control Fields ───
  pending_since_at      DateTime?
  next_action_role      Role?
  next_action_user_id   String?
  next_action_label     String?
  blocker_code          BlockerCode?
  blocker_note          String?
  overdue_flag          Boolean      @default(false)
  overdue_reason        String?
  last_activity_at      DateTime?
  entered_stage_at      DateTime?
  sla_due_at            DateTime?
  sla_breached          Boolean      @default(false)
  exception_flags       ExceptionFlag[]
  reopened_at           DateTime?
  reopened_by_id        String?
  reopen_reason         String?
  created_at                  DateTime    @default(now())
  updated_at                  DateTime    @updatedAt

  buyer                 Buyer    @relation("OrderBuyer", fields: [buyer_id], references: [id])
  creator               User     @relation("OrderCreatedBy", fields: [created_by], references: [id])
  assigned_sample_pm    User?    @relation("OrderAssignedSamplePM", fields: [assigned_sample_pm_id], references: [id])
  assigned_production_pm User?   @relation("OrderAssignedProductionPM", fields: [assigned_production_pm_id], references: [id])
  pm_accepted_by        User?    @relation("OrderPMAcceptedBy", fields: [pm_accepted_by_id], references: [id])
  material_completed_by User?    @relation("OrderMaterialCompletedBy", fields: [material_completed_by_id], references: [id])
  production_started_by User?    @relation("OrderProductionStartedBy", fields: [production_started_by_id], references: [id])
  production_completed_by User?  @relation("OrderProductionCompletedBy", fields: [production_completed_by_id], references: [id])
  reopened_by           User?    @relation("OrderReopenedBy", fields: [reopened_by_id], references: [id])
  next_action_user      User?    @relation("OrderNextActionUser", fields: [next_action_user_id], references: [id])
  lines                 OrderLine[]
  material_requirements MaterialRequirement[]
  material_requests     MaterialRequest[]
  expenses              ExpenseRequest[]
  comments              Comment[]  @relation("OrderComments")
  cost_summary          OrderCostSummary?

  @@index([buyer_id])
  @@index([status])
  @@index([order_type])
  @@index([created_by])
  @@index([created_at])
  @@index([blocker_code])
  @@index([overdue_flag])
  @@index([sla_breached])
}

model OrderLine {
  id          String   @id @default(uuid())
  order_id    String
  style_id    String
  description String?
  quantity    Float
  rate        Float
  amount      Float
  created_at  DateTime @default(now())

  order Order @relation(fields: [order_id], references: [id], onDelete: Cascade)
  style Style @relation(fields: [style_id], references: [id])

  @@index([order_id])
  @@index([style_id])
}

model MaterialRequirement {
  id                    String                    @id @default(uuid())
  order_id              String
  buyer_id              String
  style_id              String
  production_manager_id String
  store_manager_id      String?
  required_by_date      DateTime
  special_instructions  String?
  status                MaterialRequirementStatus @default(PENDING_STORE_ACCEPTANCE)
  decline_reason        String?
  // ─── Operational Control Fields ───
  pending_since_at      DateTime?
  next_action_role      Role?
  next_action_label     String?
  blocker_code          BlockerCode?
  blocker_note          String?
  overdue_flag          Boolean                   @default(false)
  last_activity_at      DateTime?
  entered_stage_at      DateTime?
  sla_due_at            DateTime?
  sla_breached          Boolean                   @default(false)
  exception_flags       ExceptionFlag[]
  created_at            DateTime                  @default(now())
  updated_at            DateTime                  @updatedAt

  order              Order                     @relation(fields: [order_id], references: [id])
  buyer              Buyer                     @relation("MaterialRequirementBuyer", fields: [buyer_id], references: [id])
  style              Style                     @relation("MaterialRequirementStyle", fields: [style_id], references: [id])
  production_manager User                      @relation("MaterialRequirementPM", fields: [production_manager_id], references: [id])
  store_manager      User?                     @relation("MaterialRequirementSM", fields: [store_manager_id], references: [id])
  lines              MaterialRequirementLine[]
  requests           MaterialRequest[]
  comments           Comment[]                 @relation("MaterialRequirementComments")

  @@index([order_id])
  @@index([buyer_id])
  @@index([style_id])
  @@index([production_manager_id])
  @@index([store_manager_id])
  @@index([status])
  @@index([blocker_code])
}

model MaterialRequirementLine {
  id             String   @id @default(uuid())
  requirement_id String
  material_name  String
  description    String?
  quantity       Float
  unit           String
  created_at     DateTime @default(now())

  requirement MaterialRequirement @relation(fields: [requirement_id], references: [id], onDelete: Cascade)

  @@index([requirement_id])
}

model MaterialRequest {
  id                      String         @id @default(uuid())
  request_no              String         @unique
  manager_id              String
  buyer_id                String
  order_id                String
  style_id                String?
  material_requirement_id String?
  store_location          String?
  expected_date           DateTime?
  remarks                 String?
  preferred_vendor_id     String?
  assigned_runner_id      String?
  status                  PurchaseStatus @default(PENDING_PURCHASE)
  // ─── Operational Control Fields ───
  pending_since_at      DateTime?
  next_action_role      Role?
  next_action_label     String?
  blocker_code          BlockerCode?
  blocker_note          String?
  overdue_flag          Boolean        @default(false)
  last_activity_at      DateTime?
  entered_stage_at      DateTime?
  sla_due_at            DateTime?
  sla_breached          Boolean        @default(false)
  exception_flags       ExceptionFlag[]
  created_at              DateTime       @default(now())
  updated_at              DateTime       @updatedAt

  manager          User                 @relation("MaterialRequestManager", fields: [manager_id], references: [id])
  buyer            Buyer                @relation("RequestBuyer", fields: [buyer_id], references: [id])
  order            Order                @relation(fields: [order_id], references: [id])
  style            Style?               @relation("RequestStyle", fields: [style_id], references: [id])
  requirement      MaterialRequirement? @relation(fields: [material_requirement_id], references: [id])
  preferred_vendor Vendor?              @relation("RequestPreferredVendor", fields: [preferred_vendor_id], references: [id])
  runner           User?                @relation("MaterialRequestRunner", fields: [assigned_runner_id], references: [id])
  lines            MaterialRequestLine[]
  purchases        Purchase[]
  comments         Comment[]            @relation("MaterialRequestComments")

  @@index([manager_id])
  @@index([assigned_runner_id])
  @@index([status])
  @@index([order_id])
  @@index([buyer_id])
  @@index([style_id])
  @@index([blocker_code])
}

model MaterialRequestLine {
  id              String   @id @default(uuid())
  request_id      String
  material_id     String
  style_id        String?
  description     String?
  quantity        Float
  expected_rate   Float
  expected_amount Float
  created_at      DateTime @default(now())

  request  MaterialRequest @relation(fields: [request_id], references: [id], onDelete: Cascade)
  material Material        @relation(fields: [material_id], references: [id])
  style    Style?          @relation(fields: [style_id], references: [id])

  @@index([request_id])
  @@index([material_id])
  @@index([style_id])
}

model Purchase {
  id                       String         @id @default(uuid())
  purchase_no              String         @unique
  request_id               String
  runner_id                String
  vendor_id                String
  invoice_no               String
  invoice_date             DateTime
  invoice_amount           Float
  invoice_files            String[]   @default([])
  accountant_notes         String?
  status                   PurchaseStatus @default(INVOICE_SUBMITTED)
  // ─── Operational Control Fields ───
  pending_since_at       DateTime?
  next_action_role       Role?
  next_action_label      String?
  blocker_code           BlockerCode?
  blocker_note           String?
  overdue_flag           Boolean        @default(false)
  last_activity_at       DateTime?
  entered_stage_at       DateTime?
  sla_due_at             DateTime?
  sla_breached           Boolean        @default(false)
  exception_flags        ExceptionFlag[]
  reopened_at            DateTime?
  reopened_by_id         String?
  reopen_reason          String?
  created_at               DateTime       @default(now())
  updated_at               DateTime       @updatedAt

  request      MaterialRequest     @relation(fields: [request_id], references: [id])
  runner       User                @relation("PurchaseRunner", fields: [runner_id], references: [id])
  vendor       Vendor              @relation("PurchaseVendor", fields: [vendor_id], references: [id])
  reopened_by  User?               @relation("PurchaseReopenedBy", fields: [reopened_by_id], references: [id])
  lines        PurchaseLine[]
  payments     Payment[]
  confirmation VendorConfirmation?
  comments     Comment[]           @relation("PurchaseComments")

  @@index([request_id])
  @@index([runner_id])
  @@index([vendor_id])
  @@index([status])
  @@index([blocker_code])
}

model PurchaseLine {
  id          String @id @default(uuid())
  purchase_id String
  material_id String
  style_id    String?
  quantity    Float
  rate        Float
  amount      Float

  purchase Purchase @relation(fields: [purchase_id], references: [id], onDelete: Cascade)
  material Material @relation(fields: [material_id], references: [id])
  style    Style?   @relation("PurchaseLineStyle", fields: [style_id], references: [id])

  @@index([purchase_id])
  @@index([material_id])
}

model Payment {
  id                 String        @id @default(uuid())
  purchase_id        String
  accountant_id      String
  payment_date       DateTime
  payment_method     PaymentMethod
  amount_paid        Float
  reference_id       String?
  payment_proof_path String
  notes              String?
  created_at         DateTime      @default(now())

  purchase  Purchase @relation(fields: [purchase_id], references: [id])
  accountant User    @relation("PaymentAccountant", fields: [accountant_id], references: [id])

  @@index([purchase_id])
  @@index([accountant_id])
}

model VendorConfirmation {
  id                  String        @id @default(uuid())
  purchase_id         String        @unique
  runner_id           String
  status              ConfirmStatus @default(NOT_CONFIRMED)
  shown_to_vendor_at  DateTime?
  vendor_confirmed_at DateTime?
  runner_remark       String?
  created_at          DateTime      @default(now())
  updated_at          DateTime      @updatedAt

  purchase Purchase @relation(fields: [purchase_id], references: [id])
  runner   User     @relation("ConfirmationRunner", fields: [runner_id], references: [id])

  @@index([runner_id])
  @@index([status])
}

model ExpenseRequest {
  id                 String          @id @default(uuid())
  expense_no         String          @unique
  raised_by_id       String
  buyer_id           String
  order_id           String
  style_id           String?
  expense_date       DateTime
  expense_category   ExpenseCategory
  job_work_type      String?
  description        String
  vendor_name        String?
  vendor_id          String?
  expected_amount    Float
  actual_amount      Float?
  attachment_path    String?
  payment_method     String?
  payment_date       DateTime?
  payment_reference  String?
  payment_proof_path String?
  accountant_notes   String?
  rejection_reason   String?
  status             ExpenseStatus   @default(PENDING_APPROVAL)
  // ─── Operational Control Fields ───
  pending_since_at   DateTime?
  next_action_role   Role?
  next_action_label  String?
  blocker_code       BlockerCode?
  blocker_note       String?
  overdue_flag       Boolean         @default(false)
  last_activity_at   DateTime?
  entered_stage_at   DateTime?
  sla_due_at         DateTime?
  sla_breached       Boolean         @default(false)
  exception_flags    ExceptionFlag[]
  reopened_at        DateTime?
  reopened_by_id     String?
  reopen_reason      String?
  created_at         DateTime        @default(now())
  updated_at         DateTime        @updatedAt

  raised_by   User    @relation("ExpenseRaisedBy", fields: [raised_by_id], references: [id])
  buyer       Buyer   @relation("ExpenseBuyer", fields: [buyer_id], references: [id])
  order       Order   @relation(fields: [order_id], references: [id])
  style       Style?  @relation("ExpenseStyle", fields: [style_id], references: [id])
  vendor      Vendor? @relation("ExpenseVendor", fields: [vendor_id], references: [id])
  reopened_by User?   @relation("ExpenseReopenedBy", fields: [reopened_by_id], references: [id])
  comments    Comment[] @relation("ExpenseComments")

  @@index([raised_by_id])
  @@index([status])
  @@index([buyer_id])
  @@index([order_id])
  @@index([style_id])
  @@index([blocker_code])
}

model Notification {
  id          String   @id @default(uuid())
  user_id     String
  title       String
  message     String
  entity_type String
  entity_id   String
  is_read     Boolean  @default(false)
  created_at  DateTime @default(now())

  user User @relation("UserNotification", fields: [user_id], references: [id])

  @@index([user_id])
  @@index([is_read])
  @@index([created_at])
}

model AuditLog {
  id             String   @id @default(uuid())
  entity_type    String
  entity_id      String
  action         String
  performed_by   String
  previous_state String?
  new_state      String?
  ip_address     String?
  created_at     DateTime @default(now())

  user User @relation("AuditLogUser", fields: [performed_by], references: [id])

  @@index([entity_type, entity_id])
  @@index([performed_by])
  @@index([created_at])
}

// ─── COMMENTS & MENTIONS ───

model Comment {
  id                      String            @id @default(uuid())
  entity_type             CommentEntityType
  author_id               String
  content                 String
  // Nullable FK columns — only one is set per comment
  order_id                String?
  material_requirement_id String?
  material_request_id     String?
  purchase_id             String?
  expense_id              String?
  created_at              DateTime          @default(now())
  updated_at              DateTime          @updatedAt

  author               User                 @relation("CommentAuthor", fields: [author_id], references: [id])
  mentions             CommentMention[]
  order                Order?               @relation("OrderComments", fields: [order_id], references: [id])
  material_requirement MaterialRequirement? @relation("MaterialRequirementComments", fields: [material_requirement_id], references: [id])
  material_request     MaterialRequest?     @relation("MaterialRequestComments", fields: [material_request_id], references: [id])
  purchase             Purchase?            @relation("PurchaseComments", fields: [purchase_id], references: [id])
  expense              ExpenseRequest?      @relation("ExpenseComments", fields: [expense_id], references: [id])

  @@index([entity_type, order_id])
  @@index([entity_type, purchase_id])
  @@index([entity_type, expense_id])
  @@index([author_id])
  @@index([created_at])
}

model CommentMention {
  id         String   @id @default(uuid())
  comment_id String
  user_id    String
  created_at DateTime @default(now())

  comment Comment @relation(fields: [comment_id], references: [id], onDelete: Cascade)
  user    User    @relation("MentionedUser", fields: [user_id], references: [id])

  @@unique([comment_id, user_id])
  @@index([user_id])
}

// ─── SAVED FILTERS ───

model SavedFilter {
  id         String   @id @default(uuid())
  user_id    String
  page       String   // e.g. "orders", "purchases", "expenses"
  name       String
  filter_json String  // JSON serialized filter state
  is_default Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user User @relation("UserSavedFilter", fields: [user_id], references: [id])

  @@index([user_id, page])
}

// ─── RECENT ITEMS ───

model RecentItem {
  id          String   @id @default(uuid())
  user_id     String
  entity_type String   // "order", "purchase", "expense", "tech_pack"
  entity_id   String
  entity_label String  // display label e.g. "ORD-2026-0012"
  viewed_at   DateTime @default(now())

  user User @relation("UserRecentItem", fields: [user_id], references: [id])

  @@unique([user_id, entity_type, entity_id])
  @@index([user_id, viewed_at])
}

// ─── REMINDERS ───

model Reminder {
  id             String   @id @default(uuid())
  entity_type    String
  entity_id      String
  sent_by_id     String
  target_user_id String
  message        String?
  is_auto        Boolean  @default(false)
  created_at     DateTime @default(now())

  sent_by     User @relation("ReminderSentBy", fields: [sent_by_id], references: [id])
  target_user User @relation("ReminderTargetUser", fields: [target_user_id], references: [id])

  @@index([target_user_id])
  @@index([entity_type, entity_id])
}

// ─── STAGE DURATION TRACKING ───

model StageDuration {
  id          String    @id @default(uuid())
  entity_type String    // "order", "tech_pack", "purchase", etc.
  entity_id   String
  stage       String    // status enum value
  entered_at  DateTime
  exited_at   DateTime?
  duration_hours Float?

  @@index([entity_type, entity_id])
  @@index([entity_type, stage])
}

// ─── DUPLICATE WARNING LOG ───

model DuplicateWarning {
  id              String   @id @default(uuid())
  warning_type    String   // "DUPLICATE_INVOICE", "DUPLICATE_EXPENSE", "DUPLICATE_MATERIAL_REQUEST"
  entity_type     String
  entity_id       String
  duplicate_of_id String?
  details         String   // JSON with match details
  dismissed       Boolean  @default(false)
  dismissed_by_id String?
  created_at      DateTime @default(now())

  @@index([entity_type, entity_id])
  @@index([warning_type])
}

// ─── ORDER COST SUMMARY (Realtime Cost Tracker) ───

model OrderCostSummary {
  id                    String      @id @default(uuid())
  order_id              String      @unique
  budgeted_amount       Float       @default(0)
  // Actual costs by category
  actual_material_cost  Float       @default(0)
  actual_expense_cost   Float       @default(0)
  total_actual_cost     Float       @default(0)
  // Variance
  cost_variance         Float       @default(0)
  cost_variance_pct     Float       @default(0)
  // Breakdown by payment stage
  pending_material      Float       @default(0)
  approved_material     Float       @default(0)
  paid_material         Float       @default(0)
  pending_expense       Float       @default(0)
  approved_expense      Float       @default(0)
  paid_expense          Float       @default(0)
  // Status
  cost_status           CostStatus  @default(ON_BUDGET)
  updated_at            DateTime    @updatedAt
  created_at            DateTime    @default(now())

  order Order @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@index([order_id])
  @@index([cost_status])
}
